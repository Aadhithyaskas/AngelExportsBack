# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/tamil_food_store

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

# Temporary token used between "first login" and "set password" step
JWT_TEMP_EXPIRE=15m

# Password reset token expiry (ms)
RESET_TOKEN_EXPIRE=600000

# Server
PORT=5000
CLIENT_URL=http://localhost:3000

# Email (used by utils/sendEmail.js via nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM="Tamil Authentic Foods <no-reply@tamilfoods.com>"

# Owner seed credentials (used by utils/seedOwner.js)
OWNER_EMAIL=owner@tamilfoods.com
OWNER_DUMMY_PASSWORD=Owner@123
